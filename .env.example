# omi-whisperx environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Whisper ──────────────────────────────────────────────────────────────────
WHISPER_MODEL=medium                  # tiny | base | small | medium | large-v2
WHISPER_BATCH_SIZE=16                 # lower on RPi5 (use 4)
# WHISPER_INITIAL_PROMPT=            # override bilingual Hindi/English prompt

# ── HuggingFace ──────────────────────────────────────────────────────────────
HF_TOKEN=                             # required for diarization model download

# ── Speaker matching ─────────────────────────────────────────────────────────
SPEAKER_THRESHOLD=0.80                # cosine similarity cutoff for name resolution
# PROFILES_DIR=~/.omi/speakers       # speaker embedding storage

# ── Content filter ───────────────────────────────────────────────────────────
CONTENT_FILTER=true
NLI_ENABLED=true
NLI_MODEL=typeform/distilbert-base-uncased-mnli
NLI_THRESHOLD=0.85                    # below this → escalate to Ollama

OLLAMA_ENABLED=true
OLLAMA_URL=http://192.168.0.2:11434   # point at your Ollama host
OLLAMA_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_TIMEOUT=10                     # seconds — cloud models need more time

# ── Notifications (ntfy) ─────────────────────────────────────────────────────
# NTFY_URL=https://ntfy.sh/your-topic
# NTFY_TOKEN=
