# omi-whisperx environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Whisper ──────────────────────────────────────────────────────────────────
WHISPER_MODEL=small                    # tiny | base | small | medium | large-v2
WHISPER_BATCH_SIZE=16                 # lower on RPi5 (use 4)
# WHISPER_INITIAL_PROMPT=            # override bilingual Hindi/English prompt

# ── HuggingFace ──────────────────────────────────────────────────────────────
HF_TOKEN=                             # required for diarization model download

# ── Speaker matching ─────────────────────────────────────────────────────────
SPEAKER_THRESHOLD=0.85                # cosine similarity cutoff for name resolution
# PROFILES_DIR=~/.omi/speakers       # speaker embedding storage
# FAST_SPEAKER=true                  # true=resemblyzer (~0.1s), false=pyannote (~15s)

# ── Live WebSocket ────────────────────────────────────────────────────────────
TRUST_CLIENT_VAD=true                 # trust Omi VAD Gate — skip server VAD, flush on 0.5s gap
SKIP_LIVE_ALIGN=true                  # skip word-level alignment in WS path (saves ~2s)
# MAX_QUEUE_AGE=30                    # drop utterances queued longer than N seconds

# ── Omi API (direct conversation creation — bypasses 2-min timeout) ──────────
OMI_API_KEY=                          # Omi developer API key — get from app.omi.me/apps
OMI_USER_NAME=                        # your enrolled speaker name — marks segments is_user=true
# OMI_CONV_DEBOUNCE=30               # seconds of silence before posting conversation to Omi
# OMI_API_BASE=https://api.omi.me/v1/dev/user

# ── Content filter ───────────────────────────────────────────────────────────
CONTENT_FILTER=false
NLI_ENABLED=false
NLI_MODEL=typeform/distilbert-base-uncased-mnli
NLI_THRESHOLD=0.85                    # below this → escalate to Ollama

OLLAMA_ENABLED=false
OLLAMA_URL=http://192.168.0.2:11434   # point at your Ollama host
OLLAMA_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_TIMEOUT=10                     # seconds — cloud models need more time

# ── Notifications (ntfy) ─────────────────────────────────────────────────────
# NTFY_URL=https://ntfy.sh/your-topic
# NTFY_TOKEN=
